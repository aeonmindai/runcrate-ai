{
  "name": "@runcrate/ai",
  "version": "0.1.5",
  "description": "Runcrate provider for Vercel AI SDK",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "keywords": [
    "ai-sdk",
    "vercel",
    "runcrate",
    "llm",
    "ai",
    "gpu",
    "inference"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aeonmindai/runcrate-ai"
  },
  "homepage": "https://runcrate.ai"
}
